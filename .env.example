# Copy to .env and fill in for local runs.
# In CI these are stored as GitHub Actions secrets.

# OpenRouter — used for both curate.ts and script.ts via the OpenAI SDK with a custom baseURL.
OPENROUTER_API_KEY=

# OpenAI — used directly for tts-1-hd.
OPENAI_API_KEY=

# Public base URL where docs/ is served. Used to build enclosure URLs in feed.xml.
# Replace USER with your GitHub username.
FEED_BASE_URL=https://USER.github.io/ai-briefing

# OpenAI TTS voice. Options for tts-1-hd:
#   alloy, ash, coral, echo, fable, nova, onyx, sage, shimmer
# (ballad and verse are gpt-4o-mini-tts only.)
TTS_VOICE=onyx
