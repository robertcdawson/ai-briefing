# Copy to .env and fill in for local runs.
# In CI these are stored as GitHub Actions secrets.

# OpenRouter — used for both curate.ts and script.ts via the OpenAI SDK with a custom baseURL.
OPENROUTER_API_KEY=

# OpenAI — used directly for text-to-speech.
OPENAI_API_KEY=

# Public base URL where docs/ is served. Used to build enclosure URLs in feed.xml.
# Replace USER with your GitHub username.
FEED_BASE_URL=https://USER.github.io/ai-briefing

# Apple Podcasts metadata for feed.xml.
PODCAST_AUTHOR=AI Briefing
PODCAST_SUMMARY=Daily AI news briefing — top three stories from the last 24 hours, fully scripted.
PODCAST_OWNER_NAME=AI Briefing
PODCAST_OWNER_EMAIL=noreply@example.com
PODCAST_HOST_NAME=AI Briefing
# "yes" discourages unauthorized imports into other podcast hosts. Set to "no" before intentionally migrating.
PODCAST_LOCKED=yes
# Place your square artwork file at docs/podcast-cover.jpg (1400x1400 to 3000x3000 recommended).
PODCAST_IMAGE_URL=https://USER.github.io/ai-briefing/podcast-cover.jpg
# Comma-separated iTunes categories.
PODCAST_CATEGORIES=Technology
# "true" or "false"
PODCAST_EXPLICIT=false
# "episodic" or "serial"
PODCAST_TYPE=episodic

# OpenAI TTS model. gpt-4o-mini-tts supports delivery instructions.
TTS_MODEL=gpt-4o-mini-tts

# OpenAI TTS voice.
# Common options:
#   alloy, ash, ballad, cedar, coral, echo, fable, marin, nova, onyx, sage, shimmer, verse
# TTS_VOICE is kept as the legacy Anchor fallback. Use per-speaker voices for the two-speaker format.
TTS_VOICE=onyx
TTS_ANCHOR_VOICE=onyx
TTS_ANALYST_VOICE=nova

# Per-segment OpenAI TTS timeout in milliseconds. Keep between 60000 and 600000.
TTS_TIMEOUT_MS=180000

# Audio cues/stingers between sections ("true" by default).
# Set to "false" to disable synthetic intro/transition/outro cues.
AUDIO_CUES_ENABLED=true

# Generated cue style: tone, chime, or tick.
AUDIO_CUE_STYLE=tone
